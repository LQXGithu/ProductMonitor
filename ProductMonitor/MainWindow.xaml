п»ҝ<Window x:Class="ProductMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductMonitor" xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" d:DataContext="{d:DesignInstance Type=local:ViewModel}"
        mc:Ignorable="d"
        Title="з”ҹдә§зӣ‘иҖғе№іеҸ°" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"/>
        
    </WindowChrome.WindowChrome> <!--иҮӘе®ҡд№үзӘ—еҸЈиҫ№жЎҶз•Ңйқўж ·ејҸ-->
    
    <Grid>
        <Grid.Background>
            <RadialGradientBrush>
                <GradientStop Color="#ff285173" Offset="0"/>
                <GradientStop Color="#ff244967" Offset="0.5"/>
                <GradientStop Color="#ff14273a" Offset="1"/>
            </RadialGradientBrush>
            <!--з”ұдёӯеҝғжёҗеҸҳ-->

            <!--<LinearGradientBrush>
    <GradientStop Color="#ff285173" Offset="0"/>
    <GradientStop Color="#ff244967" Offset="0.5"/>
    <GradientStop Color="#ff14273a" Offset="1"/>
</LinearGradientBrush>-->
            <!--з”ұеҜ№и§’жёҗеҸҳ-->
        </Grid.Background>
        <!--з”»еҲ·: жёҗеҸҳиғҢжҷҜ-->
        <Grid.RowDefinitions>
            <RowDefinition Height="50*"/>
            <!--еӨҙйғЁ-->
            <RowDefinition Height="675*"/>
            <!--еҶ…е®№-->
            <RowDefinition Height="25*"/>
            <!--еә•йғЁ-->
        </Grid.RowDefinitions>
        <!--еӨҙйғЁ-->
        <Border BorderThickness="0,0,0,1" BorderBrush="#5518aabd">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!--з¬¬дёҖиЎҢ-->
                <Image Source="/Resource/Images/Logo.png" Margin="10,7"/>
                <!--й»ҳи®ӨеңЁColumn="0"-->
                <!--з¬¬дәҢеҲ—-->
                <!--#region TextBlock: е·ҰеҸіжҺ’еҲ—, Run -->
                <!--TextBlock Grid.Column="1" Foreground="White" VerticalAlignment="Center">
                        <Run Text="з”ҹдә§зӣ‘жҺ§е№іеҸ°"/>-->
                <!--RunеҸҜд»Ҙз”ЁжқҘе®ҡд№үTextBlockдёӯзҡ„дёҚеҗҢTextеұһжҖ§-->
                <!--
                    <LineBreak/>
                        <Run Text="йҳ»зўҚдҪ еүҚиЎҢзҡ„пјҢе…¶е®һе°ұжҳҜдҪ иҮӘе·ұ"/>
                </TextBlock>-->
                <!--#endregion-->
                <!--#region TextBlock: дёҠдёӢжҺ’еҲ—, дёӨдёӘTextBlock -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="з”ҹдә§зӣ‘жҺ§е№іеҸ°" Foreground="White" FontSize="16"/>
                    <TextBlock Text="йҳ»зўҚдҪ еүҚиЎҢзҡ„пјҢе…¶е®һе°ұжҳҜдҪ иҮӘе·ұ" Foreground="White" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
                <!--#endregion-->
                <!--з¬¬дёүиЎҢ-->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="15"/>
                    </Grid.RowDefinitions>
                    <!--з¬¬дёҖиЎҢ-->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowButtons}" Width="40" Background="Transparent" BorderThickness="0" Command="{Binding MinimizedCommand}">
                            <!--Buttonй»ҳи®Өжңүиҫ№жЎҶ,и§ҰеҸ‘еҷЁеҸҜд»ҘиҖғиҷ‘еҺ»йҷӨжҲ–жӣҝжҚў-->
                            <iconPacks:PackIconMaterialLight Kind="Minus" Width="14" Height="14" Foreground="White"/>
                        </Button>
                        <Button Style="{StaticResource WindowButtons}" Width="40" Background="Transparent" BorderThickness="0" Command="{Binding MaximizedCommand}">
                            <iconPacks:PackIconPhosphorIcons Kind="CardsThin" Width="14" Height="14" Foreground="White"/>
                        </Button>
                        <Button Style="{StaticResource WindowButton}" Command="{Binding CloseCommand}"/>
                    </StackPanel>
                    <!--з¬¬дәҢиЎҢ-->
                    <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#5518aabd">
                        <Border.Background>
                            <VisualBrush TileMode="FlipXY" Viewport="0,0,7,7" ViewportUnits="Absolute">
                                <VisualBrush.Visual>
                                    <Line X1="0" Y1="10" X2="10" Y2="0" Stroke="Gray" StrokeThickness="1"/>
                                    <!--зәҝжқЎ-->
                                    <!--<Path Fill="Red" Data="M 50,0 L 100,100 L 0,100 Z"/>-->
                                    <!--иҮӘе®ҡд№ү: иҮӘе·ұз”ЁBlendз”»еҮәжқҘзҡ„-->
                                </VisualBrush.Visual>
                            </VisualBrush>
                            <!--з”ЁжқҘз”»жңүи§„еҫӢзҡ„еӣҫжЎҲ-->
                        </Border.Background>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        <!--еҶ…е®№,з”ЁжҲ·жҺ§д»¶еөҢе…Ҙдё»з•Ңйқў-->
        <ContentControl Grid.Row="1" Content="{Binding MonitorUC}"/>
        <!--еә•йғЁ-->
            <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#5518aabd">
                <!--з¬¬дёҖеҲ—-->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Border BorderThickness="0,1,0,0" BorderBrush="#5518aabd">
                        <Border.Background>
                            <VisualBrush TileMode="FlipXY" Viewport="0,0,7,7" ViewportUnits="Absolute">
                                <VisualBrush.Visual>
                                    <Line X1="0" Y1="10" X2="10" Y2="0" Stroke="Gray" StrokeThickness="1"/>
                                    <!--зәҝжқЎ-->
                                    <!--<Path Fill="Red" Data="M 50,0 L 100,100 L 0,100 Z"/>-->
                                    <!--иҮӘе®ҡд№ү: иҮӘе·ұз”ЁBlendз”»еҮәжқҘзҡ„-->
                                </VisualBrush.Visual>
                            </VisualBrush>
                            <!--з”ЁжқҘз”»жңүи§„еҫӢзҡ„еӣҫжЎҲ-->
                        </Border.Background>
                    </Border>
                    <!--з¬¬дәҢеҲ—-->
                    <TextBlock Grid.Column="1" Text="XX ж•ҷиӮІйӣҶеӣў зүҲжқғжүҖжңү" Foreground="White" FontSize="15" FontWeight="Bold"/>
            </Grid>
            </Border>
    </Grid>
</Window>
