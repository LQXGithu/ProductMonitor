<Window x:Class="ProductMonitor.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProductMonitor" xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" d:DataContext="{d:DesignInstance Type=local:ViewModel}"
        mc:Ignorable="d"
        Title="SettingWindow" Height="450" Width="800"  FontWeight="ExtraLight" ResizeMode="CanMinimize">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" Height="30">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"  Margin="10,0"></ContentPresenter>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#18aabd"></Setter>
                    <Setter Property="Foreground" Value="White"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBlock FontSize="14" Margin="10,0" VerticalAlignment="Center">
            <iconPacks:PackIconPhosphorIcons Kind="GearThin"/>
            <Run Text="系统配置信息"/>
        </TextBlock>
        <Button Grid.Column="1" Command="{Binding SettingCloseCommand}" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
            <Button.Style>
            <Style TargetType="Button">
                <Setter Property="Width" Value="40"/>
                <Setter Property="Background" Value="Transparent"/>
                <!--#region 自定义控件模板: Template -->
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="WindowButton_Border_One" Background="{TemplateBinding Background}">
                                <iconPacks:PackIconPhosphorIcons Kind="X" Foreground="Black" Width="14" Height="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="WindowButton_Border_One" Property="Background" Value="Red"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <!--#endregion-->
            </Style>
            </Button.Style>
        </Button>
        <Border Grid.Row="1" BorderThickness="0,0,1,0" BorderBrush="#ddd">
            <StackPanel Margin="10,0">
                <RadioButton Content="设备清单" IsChecked="True"/>
                <RadioButton Content="环境监测"/>
                <RadioButton Content="设备监测"/>
                <RadioButton Content="配置一"/>
                <RadioButton Content="配置二"/>
            </StackPanel>
        </Border>
        <!--也可以用命名空间和ViewModel层实时切换,这种比较传统-->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Hidden">
            <Frame Source="UserControls/SettingsPageUC.xaml" x:Name="frame" NavigationUIVisibility="Hidden"></Frame>
        </ScrollViewer>

    </Grid>
</Window>
