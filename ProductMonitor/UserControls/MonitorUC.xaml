<UserControl x:Class="ProductMonitor.UserControls.MonitorUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProductMonitor.UserControls" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             xmlns:productmonitor="clr-namespace:ProductMonitor" 
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             d:DataContext="{d:DesignInstance Type=productmonitor:ViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="10,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <!--左上角-->
                            <Polyline Points="0 30, 0 10, 10 0, 30 0" Stroke="#9918aabd" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <Ellipse Width="4" Height="4" Margin="24,-2,0,0"  HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <Ellipse Width="4" Height="4" Margin="-2,24,0,0" Fill="#9918aabd" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <!--右上角-->
                            <Path Data="M0 0,3 3,30 3,33 0,68 0,73 7,78 7,78,10M8 0,25 0" Stroke="#9918aabd" VerticalAlignment="Top" HorizontalAlignment="Right"/>
                            <!--左下角-->
                            <Polyline Points="0 0,0 15,10 15" Stroke="#9918aabd" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
                            <!--右下角-->
                            <Polyline Points="10 0,0,10" Stroke="#9918aabd" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            <Polygon Points="0 7,7 7,7 0" Fill="#9918aabd" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            <!--连线-->
                            <Border BorderThickness="0,1,0,0" BorderBrush="#9918aabd" Margin="30,0,78,0" VerticalAlignment="Top"/>
                            <Border BorderThickness="0,0,1,0" BorderBrush="#9918aabd" Margin="0,10" HorizontalAlignment="Right"/>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#9918aabd" Margin="10,0" VerticalAlignment="Bottom"/>
                            <Border BorderThickness="1,0,0,0" BorderBrush="#9918aabd" Margin="-0.5,15" HorizontalAlignment="Left"/>
                            <!--文字前的装饰-->
                            <Path Data="M0 0,3 0,5 4,3 8,0 8,3 4" Fill="#9918aabd" Margin="10,13"/>
                            <Path Data="M0 0,3 0,5 4,3 8,0 8,3 4" Fill="#5518aabd" Margin="16,13"/>
                            <TextBlock Text="{TemplateBinding Header}" Foreground="White" FontWeight="Bold" Margin="25,8" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <ContentPresenter ContentSource="Content" Margin="10,25,10,5"/>
                            <!--可以加逗号也可以省略-->
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>
        <!--第一行-->
        <Grid Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding DatetimeDT}" Foreground="White" FontSize="30" FontFamily="..\Resource\fonts\#Digital Display" VerticalAlignment="Center"/>
                <StackPanel Margin="15,0,0,0">
                    <TextBlock Text="{Binding DateDataDT}" Foreground="White" FontSize="10"/>
                    <TextBlock Text="{Binding DateWeekDT}" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>
                </StackPanel>
            </StackPanel>
            <!--第二列-->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Orientation="Horizontal">
                <!--<StackPanel.Resources>
                    <DataTemplate x:Key="machineCount">
                        <Border Width="15" Margin="2,0" Background="#3318aabd">
                            <TextBlock Text="{Binding}" Foreground="White" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </StackPanel.Resources>-->
                <!--#region 就挺单纯的还是用DataTemplate吧 -->
                <!--<Border Width="15" Background="red" Margin="2,0">
                    <TextBlock Text="0" Foreground="White" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border Width="15" Background="red" Margin="2,0">
                    <TextBlock Text="2" Foreground="White" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border Width="15" Background="red" Margin="2,0">
                    <TextBlock Text="9" Foreground="White" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border Width="15" Background="red" Margin="2,0">
                    <TextBlock Text="8" Foreground="White" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>-->
                <!--#endregion-->
                <TextBlock Text="机台&#13;总数" Margin="20,0" Foreground="#99ffffff" FontSize="10" VerticalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding MaChineCount}" ItemTemplate="{StaticResource machineCount}" Style="{StaticResource ProductItems}">
                    <!--<ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"></StackPanel>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>-->
                </ItemsControl>
                <TextBlock Text="生产计数" Margin="20,0" Foreground="#99ffffff" FontSize="10" VerticalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding ProductCount}" ItemTemplate="{StaticResource machineCount}" Style="{StaticResource ProductItems}">
                    <!--<ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"></StackPanel>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>-->
                </ItemsControl>
                <TextBlock Text="不良计数" Margin="20,0" Foreground="#99ffffff" FontSize="10" VerticalAlignment="Center"/>
                <ItemsControl ItemsSource="{Binding BadCount}" ItemTemplate="{StaticResource machineCount}" Style="{StaticResource ProductItems}">
                    <!--<ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"></StackPanel>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>-->
                </ItemsControl>
            </StackPanel>

            <Button Grid.Column="1" Width="80" Height="35" Margin="20,0" Command="{Binding settingCommand}" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource WindowsSetterButton}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <iconPacks:PackIconFontAwesome Kind="WrenchSolid" Foreground="White" Margin="10,0"/>
                    <TextBlock Text="配置"/>
                </StackPanel>
            </Button>
        </Grid>
        <!--第二行-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <!--第一列-->
            <UniformGrid Columns="1">
                <GroupBox Header="环境">
                    <!--上面的样式会占用记得加ContentPresenter-->
                    <ItemsControl ItemsSource="{Binding EnviroMentModelsList}">
                        <ItemsControl.ItemsPanel>
                            <!--布局-->
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <!--排列-->
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,5">
                                    <TextBlock Text="{Binding EMValue}" FontSize="16" Foreground="#ff2bedf1" Margin="0.5"/>
                                    <TextBlock Text="{Binding EMName}" FontSize="10" Foreground="#aaffffff" Margin="0.5"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>
                <GroupBox Header="产能">
                    <Grid>
                        <lvc:CartesianChart Margin="0,15,0,0">
                            <!--定义X轴数据-->
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="8:00,9:00,10:00,11:00,12:00,13:00,14:00,15:00,16:00">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="1" StrokeThickness="0"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <!--定义Y轴数据-->
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis MinValue="0" MaxValue="500">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="100" Stroke="#11ffffff"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                            <!--定义柱状图形-->
                            <lvc:CartesianChart.Series>
                                <lvc:ColumnSeries Values="300,400,480,450,380,450,450,330,340" Title="生产计数" MaxColumnWidth="10">
                                    <lvc:ColumnSeries.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#ff3fbbe6" Offset="0"/>
                                            <GradientStop Color="#ff2fbed1" Offset="1"/>
                                        </LinearGradientBrush>
                                    </lvc:ColumnSeries.Fill>
                                </lvc:ColumnSeries>
                                <!--定义柱状图形-->
                                <lvc:ColumnSeries Values="15,55,15,40,38,45,56,42,24" Title="不良计数" MaxColumnWidth="10">
                                    <lvc:ColumnSeries.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#fffb9a9a" Offset="0"/>
                                            <GradientStop Color="#ffff5151" Offset="1"/>
                                        </LinearGradientBrush>
                                    </lvc:ColumnSeries.Fill>
                                </lvc:ColumnSeries>
                            </lvc:CartesianChart.Series>
                        </lvc:CartesianChart>
                        <!--右上角-->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right">
                            <Border Height="6" Width="6" Background="#ff2fbed1" Margin="5,0"/>
                            <TextBlock Text="生产计数" FontSize="10" Foreground="#44ffffff"/>
                            <Border Height="6" Width="6" Background="#ffff5151" Margin="5,0"/>
                            <TextBlock Text="不良计数" FontSize="10" Foreground="#44ffffff"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
                <GroupBox Header="质量">
                    <lvc:CartesianChart>
                        <!--定义X轴数据-->
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Labels="1#,2#,3#,4#,5#,6#">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1" StrokeThickness="0"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <!--定义Y轴数据-->
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis MinValue="0" MaxValue="15">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="5" Stroke="#11ffffff"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>
                        <!--定义折线图形-->
                        <lvc:CartesianChart.Series>
                            <lvc:LineSeries Values="8,2,7,6,4,14" Stroke="#ff2bedf1" PointGeometrySize="0" Title="质量">
                                <lvc:LineSeries.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#552bedf1" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </lvc:LineSeries.Fill>
                            </lvc:LineSeries>
                        </lvc:CartesianChart.Series>
                    </lvc:CartesianChart>
                </GroupBox>
            </UniformGrid>
            <!--第二列-->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition Height="1.5*"/>
                </Grid.RowDefinitions>
                <!--第一行-->
                <Image Source="/Resource/Images/device.png"/>
                <!--第二列第二行-->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="18"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <!--第一行-->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <iconPacks:PackIconRemixIcon Kind="AlarmWarningLine" Foreground="#99ffffff" Margin="5,0"/>
                        <TextBlock Text="报警记录" VerticalAlignment="Center" Foreground="#99ffffff"/>
                    </StackPanel>
                    <!--第二行-->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding AlarmList}" ItemTemplate="{StaticResource WarningData}" Style="{StaticResource WarningPanel}"/>
                </Grid>
                <!--第二行第三行-->
                <!--第三行-->
                <GroupBox Grid.Row="2" Header="数据异常报错比例" Margin="0,5">
                    <!--饼形图-->
                    <lvc:PieChart InnerRadius="45" Margin="0,0,0,10">
                        <lvc:PieChart.Resources>
                            <Style TargetType="lvc:PieSeries">
                                <Setter Property="DataLabelsTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Point.SeriesView.Title}" Margin="0,0,05,0" Foreground="#44ffffff"/>
                                                <TextBlock Text="{Binding Point.SeriesView.Values[0]}" Margin="0,0,5,0" Foreground="#44ffffff"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </lvc:PieChart.Resources>
                        <!--饼形图数据-->
                        <lvc:PieChart.Series>
                            <lvc:PieSeries Values="20" Title="压差" DataLabels="True" LabelPosition="OutsideSlice" StrokeThickness="0"/>
                            <lvc:PieSeries Values="40" Title="震动" DataLabels="True" LabelPosition="OutsideSlice" StrokeThickness="0"/>
                            <lvc:PieSeries Values="10" Title="设备温度" DataLabels="True" LabelPosition="OutsideSlice" StrokeThickness="0"/>
                            <lvc:PieSeries Values="30" Title="光照" DataLabels="True" LabelPosition="OutsideSlice" StrokeThickness="0"/>
                        </lvc:PieChart.Series>
                    </lvc:PieChart>
                </GroupBox>
            </Grid>
            <!--第三列-->
            <UniformGrid Grid.Column="2" Rows="3">
                <!--第三列第一行-->
                <GroupBox Header="设备">
                    <ItemsControl ItemsSource="{Binding deviceModelList}" ItemTemplate="{StaticResource DeviceData}" Style="{StaticResource deviceItems}"/>
                </GroupBox>
                <!--第三列第二行-->
                <GroupBox Header="能耗">
                    <local:RaderUC RanderList="{Binding ObservableRaderModelList}" Margin="0,-20,0,00"></local:RaderUC>
                </GroupBox>
                <!--第三列第三行-->
                <GroupBox Header="人力">
                    <Grid Margin="0,-20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,20,0,0" VerticalAlignment="Center">
                            <TextBlock Text="870" Foreground="#99ffffff" FontSize="25" HorizontalAlignment="Center"/>
                            <TextBlock Text="在职在岗" Foreground="#55ffffff" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="缺岗统计" Foreground="#18aabd"/>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding observableStaffOutWorkModelList}" ItemTemplate="{StaticResource StaffOutWorkData}" Style="{StaticResource ItemsStaffOutWork}"/>
                        </Grid>
                    </Grid>
                </GroupBox>
            </UniformGrid>
        </Grid>
        <!--第三行-->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding workShopModelList}" Style="{StaticResource ItemsWorkShop}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="0,1,0,0" BorderBrush="#9918aabd" Background="#01a8aabd" Margin="10,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding WorkShopName}" Foreground="#18aabd" Margin="10,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="#18aabd" Margin="10,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!--链接: 取消下划线，[就挺特殊的]Command="{Binding DataContext.WorkShopCommand,RelativeSource={RelativeSource AncestorType=Window}}"-->
                    <Hyperlink TextDecorations="None" Command="{Binding DataContext.WorkShopCommand,RelativeSource={RelativeSource AncestorType=Window}}">[详情]</Hyperlink>
                            </TextBlock>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <!--第二行第一列-->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="机台总数" Foreground="White" FontSize="10"/>
                                    <TextBlock Text="{Binding TotalCount}" Foreground="#99ffffff" FontSize="30" Margin="0,5"/>
                                </StackPanel>
                                <UniformGrid Grid.Column="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding WorkingCount}" HorizontalAlignment="Center" FontSize="16" Foreground="LightSeaGreen"/>
                                        <TextBlock Text="作业" HorizontalAlignment="Center" FontSize="10" Foreground="#55ffffff"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding WrongCount}" HorizontalAlignment="Center" FontSize="16" Foreground="DarkOrange"/>
                                        <TextBlock Text="故障" HorizontalAlignment="Center" FontSize="10" Foreground="#55ffffff"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding WaitCount}" HorizontalAlignment="Center" FontSize="16" Foreground="Red"/>
                                        <TextBlock Text="等待" HorizontalAlignment="Center" FontSize="10" Foreground="#55ffffff"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding StopCount}" HorizontalAlignment="Center" FontSize="16" Foreground="Gray"/>
                                        <TextBlock Text="停机" HorizontalAlignment="Center" FontSize="10" Foreground="#55ffffff"/>
                                    </StackPanel>
                                </UniformGrid>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
